<Window x:Class="CarRentalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:CarRentalApp.ViewModels"
        Title="Аренда автомобилей"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <!-- ControlTemplate для кнопки "Забронировать" -->
        <ControlTemplate x:Key="BookButtonTemplate"
                TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="15,10">
                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                    <Viewbox Width="24"
                            Height="24"
                            Margin="0,0,10,0">
                        <Canvas Width="24"
                                Height="24">
                            <Path Fill="White"
                                    Data="M18.92,6.01C18.72,5.42 18.16,5 17.5,5H15V3H9V5H6.5C5.84,5 5.28,5.42 5.08,6.01L3,12V20C3,20.55 3.45,21 4,21H5C5.55,21 6,20.55 6,20V19H18V20C18,20.55 18.45,21 19,21H20C20.55,21 21,20.55 21,20V12L18.92,6.01M6.5,16C5.67,16 5,15.33 5,14.5C5,13.67 5.67,13 6.5,13C7.33,13 8,13.67 8,14.5C8,15.33 7.33,16 6.5,16M17.5,16C16.67,16 16,15.33 16,14.5C16,13.67 16.67,13 17.5,13C18.33,13 19,13.67 19,14.5C19,15.33 18.33,16 17.5,16M5,11L6.5,6.5H17.5L19,11H5Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="{TemplateBinding Content}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver"
                        Value="True">
                    <Setter TargetName="border"
                            Property="Background"
                            Value="#FF45A049"/>
                </Trigger>
                <Trigger Property="IsPressed"
                        Value="True">
                    <Setter TargetName="border"
                            Property="Background"
                            Value="#FF3D8B40"/>
                </Trigger>
                <Trigger Property="IsEnabled"
                        Value="False">
                    <Setter TargetName="border"
                            Property="Background"
                            Value="#FFCCCCCC"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- DataTemplate для списка автомобилей -->
        <DataTemplate x:Key="CarItemTemplate">
            <Border Background="White"
                    BorderBrush="#FFDDDDDD"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="5"
                    Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="60"
                            Height="60"
                            Grid.Column="0"
                            Margin="0,0,15,0">
                        <Canvas Width="24"
                                Height="24">
                            <Path Fill="#FF4CAF50"
                                    Data="M18.92,6.01C18.72,5.42 18.16,5 17.5,5H15V3H9V5H6.5C5.84,5 5.28,5.42 5.08,6.01L3,12V20C3,20.55 3.45,21 4,21H5C5.55,21 6,20.55 6,20V19H18V20C18,20.55 18.45,21 19,21H20C20.55,21 21,20.55 21,20V12L18.92,6.01M6.5,16C5.67,16 5,15.33 5,14.5C5,13.67 5.67,13 6.5,13C7.33,13 8,13.67 8,14.5C8,15.33 7.33,16 6.5,16M17.5,16C16.67,16 16,15.33 16,14.5C16,13.67 16.67,13 17.5,13C18.33,13 19,13.67 19,14.5C19,15.33 18.33,16 17.5,16M5,11L6.5,6.5H17.5L19,11H5Z"/>
                        </Canvas>
                    </Viewbox>

                    <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                        <TextBlock FontSize="18"
                                FontWeight="Bold"
                                Foreground="#FF333333">
                            <Run Text="{Binding Brand}"/>
                            <Run Text="{Binding Model}"/>
                        </TextBlock>
                        <TextBlock FontSize="14"
                                Foreground="#FF666666"
                                Margin="0,5,0,0">
                            <Run Text="Класс:"/>
                            <Run Text="{Binding CarClass}"
                                    FontWeight="SemiBold"/>
                        </TextBlock>
                        <TextBlock FontSize="14"
                                Foreground="#FF666666"
                                Margin="0,2,0,0">
                            <Run Text="Мест:"/>
                            <Run Text="{Binding Seats}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                        <TextBlock FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FF4CAF50"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding PricePerDay, StringFormat=N0}"/>
                            <Run Text="₽"
                                    FontSize="18"/>
                        </TextBlock>
                        <TextBlock Text="в сутки"
                                   FontSize="12"
                                   Foreground="#FF999999"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid Background="#FFF5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FF4CAF50"
                Padding="20">
            <TextBlock Text="Система аренды автомобилей"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1"
                Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#FFDDDDDD"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Доступные автомобили"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Border Grid.Row="1"
                            Background="#FFF9F9F9"
                            Padding="10"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Класс:"
                                        Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding CarClasses}"
                                          SelectedItem="{Binding SelectedClassFilter, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Мин. мест:"
                                        Margin="0,0,0,5"/>
                                <TextBox Text="{Binding MinSeats, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <Button Grid.Column="4"
                                    Content="Сброс"
                                    Command="{Binding ResetFiltersCommand}"
                                    VerticalAlignment="Bottom"
                                    Padding="15,5"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding FilteredCars}"
                             SelectedItem="{Binding SelectedCar, Mode=TwoWay}"
                             ItemTemplate="{StaticResource CarItemTemplate}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#FFDDDDDD"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Бронирование"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Автомобиль:"
                                FontWeight="SemiBold"
                                Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding SelectedCar.FullName, TargetNullValue='Не выбран'}"
                                   FontSize="16"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Начало аренды:"
                                FontWeight="SemiBold"
                                Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding CurrentBooking.StartDate, Mode=TwoWay}"
                                    Margin="0,0,0,15"/>

                        <TextBlock Text="Окончание:"
                                FontWeight="SemiBold"
                                Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding CurrentBooking.EndDate, Mode=TwoWay}"
                                    Margin="0,0,0,15"/>

                        <TextBlock Text="Дней:"
                                FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CurrentBooking.RentalDays, Mode=OneWay}"
                                   FontSize="18"
                                FontWeight="Bold"
                                Margin="0,5,0,15"/>

                        <TextBlock Text="Стоимость:"
                                FontWeight="SemiBold"/>
                        <TextBlock FontSize="28"
                                FontWeight="Bold"
                                Foreground="#FF4CAF50">
                            <Run Text="{Binding CurrentBooking.TotalCost, Mode=OneWay, StringFormat=N0}"/>
                            <Run Text="₽"/>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Row="2"
                            Content="Забронировать"
                            Command="{Binding BookCarCommand}"
                            Template="{StaticResource BookButtonTemplate}"
                            Background="#FF4CAF50"
                            BorderBrush="#FF45A049"
                            Height="50"
                            Margin="0,20,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>