@model PhotoGallery.ViewModels.ImageViewModel

<h1>Добавить изображение</h1>

<form method="post">

    <div>
        <label>Название</label>
        <br />

        <input asp-for="Title" />

        <br />

        <span asp-validation-for="Title" style="color:red;"></span>
    </div>

    <br />

    <div>
        <label>URL изображения</label>
        <br />

        <input asp-for="Url" style="width:400px;" />

        <br />

        <span asp-validation-for="Url" style="color:red;"></span>
    </div>

    <br />

    <div>
        <label>Описание</label>
        <br />

        <textarea asp-for="Description"></textarea>

        <br />

        <span asp-validation-for="Description" style="color:red;"></span>
    </div>

    <br />

    <button type="submit">
        Добавить
    </button>

</form>