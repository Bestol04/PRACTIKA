<Window x:Class="CarRentalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarRentalApp"
        Title="🚗 Аренда автомобилей"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2196F3" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🚗 Аренда автомобилей"
                               Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentUserInfo}"
                               Foreground="#E3F2FD" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="💬 Чат"
                            Command="{Binding OpenChatCommand}"
                            Background="White" Foreground="#2196F3" FontWeight="Bold"/>
                    <Button Content="Выход"
                            Command="{Binding LogoutCommand}"
                            Background="#E53935" Foreground="White"
                            Margin="8,4,0,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Доступные автомобили"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListView ItemsSource="{Binding AvailableCars}"
                              SelectedItem="{Binding SelectedCar}"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Марка" DisplayMemberBinding="{Binding Brand}" Width="100"/>
                                <GridViewColumn Header="Модель" DisplayMemberBinding="{Binding Model}" Width="120"/>
                                <GridViewColumn Header="Цена/день" DisplayMemberBinding="{Binding PricePerDay, StringFormat=C}" Width="100"/>
                                <GridViewColumn Header="Статус" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Доступен"/>
                                                        <Setter Property="Foreground" Value="Green"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="Text" Value="Занят"/>
                                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12" Margin="4,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Оформление аренды" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

                    <TextBlock Text="Имя клиента:" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Срок аренды (дней):" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding RentalDays, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Выбран:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding SelectedCar.FullName, TargetNullValue='—'}"
                               FontSize="14" Foreground="#2196F3"/>

                    <TextBlock Text="Стоимость:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding TotalRentalCost, StringFormat=C}"
                               FontSize="18" FontWeight="Bold" Foreground="#388E3C"/>

                    <Button Content="Арендовать"
                            Command="{Binding RentCarCommand}"
                            Background="#4CAF50" Foreground="White" FontWeight="Bold"
                            Margin="0,12,0,4"/>

                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,4"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#555"
                               FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Активные аренды"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ActiveRentals}"
                             SelectedItem="{Binding SelectedRental}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Car.FullName}" FontWeight="SemiBold"/>
                                    <TextBlock FontSize="11" Foreground="Gray">
                                        <Run Text="{Binding ClientName}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding DaysRented}"/>
                                        <Run Text=" дн."/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding TotalCost, StringFormat=C}" FontSize="11" Foreground="#388E3C"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2" Content="Возврат"
                            Command="{Binding ReturnCarCommand}"
                            Background="#FF9800" Foreground="White" FontWeight="Bold"
                            Margin="0,8,0,4"/>

                    <TextBlock Grid.Row="3" Text="Уведомления"
                               FontSize="14" FontWeight="Bold" Margin="0,12,0,4"/>
                    <ListBox Grid.Row="4" ItemsSource="{Binding Notifications}"
                             BorderThickness="0" Background="#FAFAFA"
                             FontSize="11"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#ECEFF1" Padding="12,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#37474F"/>
        </Border>
    </Grid>
</Window>
