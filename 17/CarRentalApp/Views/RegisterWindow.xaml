<Window x:Class="CarRentalApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CarRentalApp.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Регистрация"
        Height="720"
        Width="460"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        ResizeMode="CanResize">

    <Window.Resources>
        <ObjectDataProvider x:Key="UserRoles"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:UserRole"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Border Background="White"
                Margin="20"
                CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.3"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <Label Content="Полное имя:" Margin="0,0,0,0"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Имя пользователя:"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Пароль:"/>
                    <PasswordBox x:Name="PasswordBox"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <Label Content="Подтвердите пароль:"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                    <Label Content="Роль:"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource UserRoles}}"
                              SelectedItem="{Binding SelectedRole}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="Client">
                                                    <Setter Property="Text" Value="Клиент"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Manager">
                                                    <Setter Property="Text" Value="Менеджер"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Admin">
                                                    <Setter Property="Text" Value="Администратор"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="Red"
                               FontSize="12"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               MinHeight="18"/>

                    <Button Content="Зарегистрироваться"
                            Command="{Binding RegisterCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            Margin="0,12,0,4"/>

                    <Button Content="Отмена"
                            Click="CancelButton_Click"
                            Background="#9E9E9E"
                            Foreground="White"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
