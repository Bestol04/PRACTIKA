<Window x:Class="CarRentalApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CarRentalApp.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Регистрация"
        Height="550"
                Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

        <Window.Resources>
                <ObjectDataProvider x:Key="UserRoles"
                                    MethodName="GetValues"
                                    ObjectType="{x:Type sys:Enum}">
                        <ObjectDataProvider.MethodParameters>
                                <x:Type TypeName="models:UserRole"/>
                        </ObjectDataProvider.MethodParameters>
                </ObjectDataProvider>

                <Style TargetType="TextBox">
                        <Setter Property="Padding"
                                        Value="10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,5"/>
                </Style>

                <Style TargetType="PasswordBox">
                        <Setter Property="Padding"
                                        Value="10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,5"/>
                </Style>

                <Style TargetType="ComboBox">
                        <Setter Property="Padding"
                                        Value="10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,5"/>
                </Style>

                <Style TargetType="Button">
                        <Setter Property="Padding"
                                        Value="15,10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,10,0,5"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                </Style>
        </Window.Resources>

        <Grid Background="#F5F5F5">
                <Border Background="White"
                        Margin="40"
                        Padding="30"
                        CornerRadius="10">
                        <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                                                  ShadowDepth="3"
                                                  Opacity="0.3"/>
                        </Border.Effect>

                        <StackPanel>
                                <!-- Заголовок -->
                                <TextBlock Text="Регистрация"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,30"/>

                                <!-- Полное имя -->
                                <Label Content="Полное имя:"
                                                FontWeight="SemiBold"/>
                                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- Имя пользователя -->
                                <Label Content="Имя пользователя:"
                                                FontWeight="SemiBold"
                                                Margin="0,10,0,0"/>
                                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- Пароль -->
                                <Label Content="Пароль:"
                                                FontWeight="SemiBold"
                                                Margin="0,10,0,0"/>
                                <PasswordBox x:Name="PasswordBox"
                                                PasswordChanged="PasswordBox_PasswordChanged"/>

                                <!-- Подтверждение пароля -->
                                <Label Content="Подтвердите пароль:"
                                                FontWeight="SemiBold"
                                                Margin="0,10,0,0"/>
                                <PasswordBox x:Name="ConfirmPasswordBox"
                                                PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                                <!-- Роль -->
                                <Label Content="Роль:"
                                                FontWeight="SemiBold"
                                                Margin="0,10,0,0"/>
                                <ComboBox ItemsSource="{Binding Source={StaticResource UserRoles}}"
                                          SelectedItem="{Binding SelectedRole}">
                                        <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                        <TextBlock>
                                                                <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding}"
                                                                                                        Value="Client">
                                                                                                <Setter Property="Text"
                                                                                                                Value="👤 Клиент"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding}"
                                                                                                        Value="Manager">
                                                                                                <Setter Property="Text"
                                                                                                                Value="💼 Менеджер"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding}"
                                                                                                        Value="Admin">
                                                                                                <Setter Property="Text"
                                                                                                                Value="⚙️ Администратор"/>
                                                                                        </DataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </TextBlock.Style>
                                                        </TextBlock>
                                                </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Статус -->
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="Red"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           Margin="0,10"/>

                                <!-- Кнопка регистрации -->
                                <Button Content="Зарегистрироваться"
                                        Command="{Binding RegisterCommand}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        FontWeight="Bold"/>

                                <Button Content="Отмена"
                                        Click="CancelButton_Click"
                                        Background="#9E9E9E"
                                        Foreground="White"/>
                        </StackPanel>
                </Border>
        </Grid>
</Window>