<Window x:Class="CarRentalApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="560"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Border Background="White"
                Margin="20"
                CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.3"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>
                    <TextBlock Text="🚗 Аренда автомобилей"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Вход в систему"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Foreground="Gray"
                               Margin="0,0,0,18"/>

                    <Label Content="Имя пользователя:" Margin="0,0,0,0"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Пароль:"/>
                    <PasswordBox x:Name="PasswordBox"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="Red"
                               FontSize="12"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               MinHeight="18"/>

                    <Button Content="Войти"
                            Command="{Binding LoginCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            Margin="0,12,0,4"/>

                    <Button Content="Регистрация"
                            Command="{Binding RegisterCommand}"
                            Background="#2196F3"
                            Foreground="White"/>

                    <Border BorderBrush="LightGray"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,18,0,0"
                            CornerRadius="5"
                            Background="#FFFEF0">
                        <StackPanel>
                            <TextBlock Text="Тестовый доступ:"
                                       FontWeight="Bold"
                                       FontSize="12"/>
                            <TextBlock Text="Логин: admin" FontSize="11"/>
                            <TextBlock Text="Пароль: admin123" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
