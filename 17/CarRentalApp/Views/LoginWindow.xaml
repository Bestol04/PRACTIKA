<Window x:Class="CarRentalApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="400"
                Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

        <Window.Resources>
                <Style TargetType="TextBox">
                        <Setter Property="Padding"
                                        Value="10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,5"/>
                </Style>

                <Style TargetType="PasswordBox">
                        <Setter Property="Padding"
                                        Value="10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,5"/>
                </Style>

                <Style TargetType="Button">
                        <Setter Property="Padding"
                                        Value="15,10"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Margin"
                                        Value="0,10,0,5"/>
                        <Setter Property="Cursor"
                                        Value="Hand"/>
                </Style>
        </Window.Resources>

        <Grid Background="#F5F5F5">
                <Border Background="White"
                        Margin="50"
                        Padding="30"
                        CornerRadius="10">
                        <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                                                  ShadowDepth="3"
                                                  Opacity="0.3"/>
                        </Border.Effect>

                        <StackPanel>
                                <!-- Заголовок -->
                                <TextBlock Text="🚗 Аренда автомобилей"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Вход в систему"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           Foreground="Gray"
                                           Margin="0,0,0,30"/>

                                <!-- Имя пользователя -->
                                <Label Content="Имя пользователя:"
                                                FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- Пароль -->
                                <Label Content="Пароль:"
                                                FontWeight="SemiBold"
                                                Margin="0,10,0,0"/>
                                <PasswordBox x:Name="PasswordBox"
                                                PasswordChanged="PasswordBox_PasswordChanged"/>

                                <!-- Статус -->
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="Red"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           Margin="0,10"
                                           MinHeight="20"/>

                                <!-- Кнопки -->
                                <Button Content="Войти"
                                        Command="{Binding LoginCommand}"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        FontWeight="Bold"/>

                                <Button Content="Регистрация"
                                        Command="{Binding RegisterCommand}"
                                        Background="#2196F3"
                                        Foreground="White"/>

                                <!-- Данные для теста -->
                                <Border BorderBrush="LightGray"
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,20,0,0"
                                        CornerRadius="5"
                                        Background="#FFFEF0">
                                        <StackPanel>
                                                <TextBlock Text="Тестовый доступ:"
                                                           FontWeight="Bold"
                                                           FontSize="12"/>
                                                <TextBlock Text="Логин: admin"
                                                                FontSize="11"/>
                                                <TextBlock Text="Пароль: admin123"
                                                                FontSize="11"/>
                                        </StackPanel>
                                </Border>
                        </StackPanel>
                </Border>
        </Grid>
</Window>