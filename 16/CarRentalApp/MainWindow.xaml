<Window x:Class="CarRentalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:CarRentalApp.ViewModels"
        xmlns:local="clr-namespace:CarRentalApp"
        Title="🚗 Система аренды автомобилей"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:CarRentalViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Конвертеры -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <!-- Стили -->
        <Style TargetType="Button">
            <Setter Property="Padding"
                    Value="15,8"/>
            <Setter Property="Margin"
                    Value="5"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="5"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Margin"
                    Value="5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"
                    Value="5"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Margin"
                    Value="5"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Margin"
                    Value="5,5,5,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Система аренды автомобилей"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Аренда -->
            <GroupBox Grid.Column="0"
                      Header="Оформление аренды"
                      Margin="0,0,5,0"
                      Padding="10">
                <StackPanel>
                    <!-- Выбор автомобиля -->
                    <Label Content="Выберите автомобиль:"
                           FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AvailableCars}"
                              SelectedItem="{Binding SelectedCar}"
                              DisplayMemberPath="FullName">
                    </ComboBox>

                    <!-- Информация о выбранном автомобиле -->
                    <Border BorderBrush="LightGray"
                            BorderThickness="1"
                            Margin="5,10"
                            Padding="10"
                            CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCar}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCar, Converter={StaticResource NullToVisibilityConverter}}"
                                                 Value="Visible">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"
                                       Text="{Binding SelectedCar.FullName}"/>
                            <TextBlock FontSize="14"
                                       Foreground="Green"
                                       Text="{Binding SelectedCar.PricePerDay, StringFormat='Цена: {0:C} / день'}"/>
                        </StackPanel>
                    </Border>

                    <!-- Имя клиента -->
                    <Label Content="Имя клиента:"
                           FontWeight="SemiBold"
                           Margin="5,10,5,0"/>
                    <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Количество дней -->
                    <Label Content="Количество дней аренды:"
                           FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding RentalDays, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100"/>
                        <TextBlock Text="дней"
                                   VerticalAlignment="Center"
                                   Margin="10,0"/>
                    </StackPanel>

                    <!-- Расчет стоимости -->
                    <Border Background="LightBlue"
                            Padding="10"
                            Margin="5,15,5,5"
                            CornerRadius="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCar, Converter={StaticResource NullToVisibilityConverter}}"
                                                 Value="Visible">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Стоимость аренды:"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                            <TextBlock FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="DarkGreen"
                                       Text="{Binding TotalRentalCost, StringFormat={}{0:C}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка аренды -->
                    <Button Content="Арендовать автомобиль"
                            Command="{Binding RentCarCommand}"
                            Background="LightGreen"
                            FontWeight="Bold"
                            Margin="5,15,5,5"
                            Height="40"/>

                    <!-- Индикатор загрузки -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="⏳"
                                   FontSize="20"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Обработка запроса..."
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Правая панель - Активные аренды -->
            <GroupBox Grid.Column="1"
                      Header="Активные аренды"
                      Margin="5,0,0,0"
                      Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Список активных аренд -->
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding ActiveRentals}"
                             SelectedItem="{Binding SelectedRental}"
                             Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightBlue"
                                        BorderThickness="1"
                                        Padding="8"
                                        Margin="2"
                                        CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold"
                                                   FontSize="14"
                                                   Text="{Binding Car.FullName}"/>
                                        <TextBlock Margin="0,3,0,0"
                                                   Text="{Binding ClientName, StringFormat='Клиент: {0}'}"/>
                                        <TextBlock Text="{Binding DaysRented, StringFormat='Дней: {0}'}"/>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="Green"
                                                   Text="{Binding TotalCost, StringFormat='Стоимость: {0:C}'}"/>
                                        <TextBlock FontSize="11"
                                                   Foreground="Gray"
                                                   Margin="0,3,0,0"
                                                   Text="{Binding RentalDate, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Кнопка возврата -->
                    <Button Grid.Row="1"
                            Content="Вернуть автомобиль"
                            Command="{Binding ReturnCarCommand}"
                            Background="LightCoral"
                            FontWeight="Bold"
                            Height="40"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Строка состояния -->
        <Border Grid.Row="2"
                Background="LightGray"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0"
                Padding="10"
                Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>