@model List<PhotoGallery.Models.Photo>

<h1>Галерея изображений</h1>

<a href="/Gallery/Add">Добавить изображение</a>

<div style="display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
    margin-top:20px;">

    @foreach (var photo in Model)
    {
        <div style="border:1px solid gray;
            padding:10px;">

            <img src="@photo.Url" style="width:100%;
            height:200px;
            object-fit:cover;" />

            <h3>@photo.Title</h3>

            <p>@photo.DateUploaded</p>

            <a href="/Gallery/Show/@photo.Id">
                Открыть
            </a>

        </div>
    }

</div>