<Window x:Class="CarRentalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Аренда автомобилей"
        Height="450"
        Width="800">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Привязка данных -->
        <ListView Grid.Row="0"
                  ItemsSource="{Binding Cars}"
                  SelectedItem="{Binding SelectedCar}">

            <ListView.View>
                <GridView>

                    <GridViewColumn Header="Марка"
                                    DisplayMemberBinding="{Binding Brand}"/>

                    <GridViewColumn Header="Модель"
                                    DisplayMemberBinding="{Binding Model}"/>

                    <GridViewColumn Header="Год"
                                    DisplayMemberBinding="{Binding Year}"/>

                    <GridViewColumn Header="Арендована"
                                    DisplayMemberBinding="{Binding IsRented}"/>

                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

            <Button Content="Арендовать"
                    Width="120"
                    Margin="5"
                    Command="{Binding RentCarCommand}"/>

            <Button Content="Вернуть"
                    Width="120"
                    Margin="5"
                    Command="{Binding ReturnCarCommand}"/>

        </StackPanel>

    </Grid>
</Window>